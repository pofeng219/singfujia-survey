rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }

    function isValidSurvey(data) {
      return data.keys().hasAll(['ownerId', 'type', 'data', 'createdAt'])
        && data.ownerId is string && data.ownerId.size() > 0 && data.ownerId == request.auth.uid
        && data.type is string && data.type.size() > 0 && data.type.size() <= 64
        && data.data is map
        && data.createdAt is timestamp;
    }

    // Surveys Collection
    match /surveys/{surveyId} {
      allow get: if isVerified() && isValidId(surveyId) && existing().ownerId == request.auth.uid;
      allow list: if isVerified() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isVerified() 
                    && isValidId(surveyId)
                    && isValidSurvey(incoming()) 
                    && incoming().keys().size() == 5
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
                    
      allow update: if isVerified() 
                    && isValidId(surveyId)
                    && isValidSurvey(incoming())
                    && incoming().ownerId == existing().ownerId
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['data', 'type', 'updatedAt']);
                    
      allow delete: if isVerified() && isValidId(surveyId) && existing().ownerId == request.auth.uid;
    }
    
    // Default fallback
    match /{path=**}/surveys/{surveyId} {
      allow read, write: if false;
    }
  }
}
