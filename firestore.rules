rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    // Only allow verified emails if strictly required, but for seniors/simplicity using Google auth we can skip email_verified check or assume it's true.
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /userDrafts/{userId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidId(userId);
    }
  }
}
