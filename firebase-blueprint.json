{
  "entities": {
    "UserDraft": {
      "title": "User Draft",
      "description": "Stores user survey drafts",
      "type": "object",
      "properties": {
        "house": { "type": "object" },
        "land": { "type": "object" },
        "factory": { "type": "object" },
        "parking": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/userDrafts/{userId}": {
      "schema": { "$ref": "#/entities/UserDraft" },
      "description": "User's draft data"
    }
  }
}
